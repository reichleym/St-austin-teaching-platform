generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  DEPARTMENT_HEAD
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum SignupMode {
  INVITE_ONLY
  OPEN_WITH_CUTOFF
}

enum GradeEditRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EnrollmentStatus {
  ACTIVE
  DROPPED
  COMPLETED
}

enum CourseVisibility {
  DRAFT
  PUBLISHED
}

enum ProgramVisibility {
  DRAFT
  PUBLISHED
}

enum ModuleVisibilityRule {
  ALL_VISIBLE
  LIMITED_ACCESS
}

enum LessonVisibility {
  VISIBLE
  HIDDEN
}

enum LessonAttachmentKind {
  FILE
  PDF
  VIDEO_LINK
}

enum AdminActionType {
  INVITE_TEACHER
  INVITE_STUDENT
  ENABLE_USER
  DISABLE_USER
  TOGGLE_STUDENT_SELF_SIGNUP
  SET_SIGNUP_CUTOFF
  APPROVE_GRADE_EDIT_REQUEST
  REJECT_GRADE_EDIT_REQUEST
  CREATE_ANNOUNCEMENT
  UPDATE_ANNOUNCEMENT
  DELETE_ANNOUNCEMENT
  UPDATE_SYSTEM_SETTINGS
}

enum AnnouncementAudience {
  BOTH
  TEACHER_ONLY
  STUDENT_ONLY
  DEPARTMENT_HEAD_ONLY
  TEACHER_DEPARTMENT_HEAD
  STUDENT_DEPARTMENT_HEAD
  ALL
}

enum InstructionThreadStatus {
  OPEN // student submitted, waiting for teacher
  ANSWERED // teacher has replied
  CLOSED // resolved, no more replies allowed
}

enum InstructionThreadScope {
  COURSE // question is about the course in general
  MODULE // question is about a specific module
}

model User {
  id                        String                    @id @default(cuid())
  name                      String?
  email                     String                    @unique
  emailVerified             DateTime?
  image                     String?
  passwordHash              String
  role                      Role                      @default(STUDENT)
  status                    UserStatus                @default(ACTIVE)
  phone                     String?
  guardianName              String?
  guardianPhone             String?
  country                   String?
  state                     String?
  department                String?
  studentId                 String?                   @unique
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  accounts                  Account[]
  sessions                  Session[]
  createdInvitations        Invitation[]              @relation("InvitationCreatedBy")
  createdAnnouncements      Announcement[]            @relation("AnnouncementCreatedBy")
  updatedAnnouncements      Announcement[]            @relation("AnnouncementUpdatedBy")
  taughtCourses             Course[]                  @relation("CourseTeacher")
  enrollments               Enrollment[]
  gradesAwarded             Grade[]                   @relation("GradeAwardedBy")
  gradeRecords              Grade[]                   @relation("GradeStudent")
  gradeEditSubjectRequests  GradeEditRequest[]        @relation("GradeEditStudent")
  discussionParticipations  DiscussionParticipation[]
  submittedGradeEditRequest GradeEditRequest[]        @relation("GradeEditRequestedBy")
  reviewedGradeEditRequest  GradeEditRequest[]        @relation("GradeEditReviewedBy")
  lessonCompletions         LessonCompletion[]
  adminActions              AdminActionLog[]          @relation("AdminActionActor")
  targetedAdminActions      AdminActionLog[]          @relation("AdminActionTargetUser")
  settingsUpdates           SystemSettings[]          @relation("SystemSettingsUpdatedBy")
  instructionThreads        InstructionThread[]       @relation("ThreadStudent")
  instructionMessages       InstructionMessage[]      @relation("MessageAuthor")
  pagesUpdated              DynamicPage[]             @relation("PagesUpdatedBy")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Invitation {
  id            String    @id @default(cuid())
  email         String
  name          String?
  phone         String?
  department    String?
  guardianName  String?
  guardianPhone String?
  country       String?
  state         String?
  studentId     String?
  role          Role
  token         String    @unique
  expiresAt     DateTime
  acceptedAt    DateTime?
  createdBy     User      @relation("InvitationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([role, expiresAt])
}

model SystemSettings {
  id                         Int        @id @default(1)
  studentSelfSignupEnabled   Boolean    @default(false)
  studentSignupCutoffDate    DateTime?
  signupMode                 SignupMode @default(INVITE_ONLY)
  gradeScale                 Json?
  lateSubmissionPenaltyRules Json?
  dashboardCalendarEvents    Json?
  universityCareers          Json?
  updatedById                String?
  updatedBy                  User?      @relation("SystemSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt                  DateTime   @default(now())
  updatedAt                  DateTime   @updatedAt
}

model Announcement {
  id          String               @id @default(cuid())
  title       String
  content     String
  sourceLanguage String            @default("en")
  translations Json?
  isGlobal    Boolean              @default(true)
  audience    AnnouncementAudience @default(BOTH)
  expiresAt   DateTime?
  createdById String
  createdBy   User                 @relation("AnnouncementCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById String?
  updatedBy   User?                @relation("AnnouncementUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([isGlobal, expiresAt])
  @@index([audience, expiresAt])
}

model Course {
  id                 String              @id @default(cuid())
  code               String              @unique
  title              String
  description        String?
  programContent     String?
  startDate          DateTime?
  endDate            DateTime?
  visibility         CourseVisibility    @default(DRAFT)
  teacherId          String?
  teacher            User?               @relation("CourseTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  assignments        Assignment[]
  discussions        Discussion[]
  enrollments        Enrollment[]
  modules            CourseModule[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  instructionThreads InstructionThread[]
  programs           ProgramCourse[]
}

model Program {
  id                 String   @id @default(cuid())
  code               String   @unique
  title              String
  degreeLevel        String?
  fieldOfStudy       String?
  description        String?
  programContent     String?
  sourceLanguage     String              @default("en")
  translations       Json?
  visibility         ProgramVisibility @default(DRAFT)
  courses            ProgramCourse[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ProgramCourse {
  programId String
  courseId  String

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([programId, courseId])
}

model CourseModule {
  id                 String               @id @default(cuid())
  courseId           String
  course             Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title              String
  description        String?
  position           Int                  @default(0)
  releaseAt          DateTime?
  visibilityRule     ModuleVisibilityRule @default(ALL_VISIBLE)
  lessons            Lesson[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  instructionThreads InstructionThread[]

  @@index([courseId, position])
}

model Lesson {
  id          String             @id @default(cuid())
  moduleId    String
  module      CourseModule       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  content     String?
  position    Int                @default(0)
  visibility  LessonVisibility   @default(VISIBLE)
  isRequired  Boolean            @default(true)
  embedUrl    String?
  attachments LessonAttachment[]
  completions LessonCompletion[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([moduleId, position])
}

model LessonAttachment {
  id         String               @id @default(cuid())
  lessonId   String
  lesson     Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  kind       LessonAttachmentKind @default(FILE)
  label      String?
  fileName   String?
  mimeType   String?
  sizeBytes  Int?
  storageKey String?
  publicUrl  String?
  createdAt  DateTime             @default(now())

  @@index([lessonId, kind])
}

model LessonCompletion {
  id          String   @id @default(cuid())
  lessonId    String
  studentId   String
  completedAt DateTime @default(now())
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([lessonId, studentId])
  @@index([studentId, completedAt])
}

model Assignment {
  id                String             @id @default(cuid())
  courseId          String
  course            Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  dueAt             DateTime?
  maxPoints         Decimal            @default(100) @db.Decimal(6, 2)
  grades            Grade[]
  gradeEditRequests GradeEditRequest[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}
model HomePage {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  route     String
  sections  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model HomeSection {
  id           String   @id @default(cuid())
  pageId       String
  page         DynamicPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  sectionKey   String
  componentType String
  position     Int      @default(0)
  content      Json

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([pageId, sectionKey])
  @@index([pageId, position])
}

model Discussion {
  id             String                    @id @default(cuid())
  courseId       String
  course         Course                    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title          String
  content        String?
  isClosed       Boolean                   @default(false)
  participations DiscussionParticipation[]
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
}

model DiscussionParticipation {
  id             String     @id @default(cuid())
  discussionId   String
  studentId      String
  postsCount     Int        @default(0)
  completionRate Int        @default(0)
  lastPostedAt   DateTime?
  discussion     Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  student        User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([discussionId, studentId])
}

model Enrollment {
  id         String           @id @default(cuid())
  courseId   String
  studentId  String
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  course     Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student    User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
}

model Grade {
  id           String     @id @default(cuid())
  assignmentId String
  studentId    String
  awardedById  String?
  points       Decimal    @db.Decimal(6, 2)
  publishedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User       @relation("GradeStudent", fields: [studentId], references: [id], onDelete: Cascade)
  awardedBy    User?      @relation("GradeAwardedBy", fields: [awardedById], references: [id], onDelete: SetNull)

  @@unique([assignmentId, studentId])
}

model GradeEditRequest {
  id             String                 @id @default(cuid())
  assignmentId   String
  studentId      String
  requestedById  String
  reason         String
  proposedPoints Decimal?               @db.Decimal(6, 2)
  status         GradeEditRequestStatus @default(PENDING)
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  assignment     Assignment             @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student        User                   @relation("GradeEditStudent", fields: [studentId], references: [id], onDelete: Cascade)
  requestedBy    User                   @relation("GradeEditRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  reviewedBy     User?                  @relation("GradeEditReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([assignmentId, studentId])
}

model AdminActionLog {
  id           String          @id @default(cuid())
  action       AdminActionType
  actorId      String
  targetUserId String?
  entityType   String?
  entityId     String?
  metadata     Json?
  createdAt    DateTime        @default(now())
  actor        User            @relation("AdminActionActor", fields: [actorId], references: [id], onDelete: Restrict)
  targetUser   User?           @relation("AdminActionTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([actorId, createdAt])
}

model InstructionThread {
  id String @id @default(cuid())

  /// The student who opened this thread
  studentId String
  student   User   @relation("ThreadStudent", fields: [studentId], references: [id], onDelete: Cascade)

  /// Which course this thread belongs to (always required)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  /// Optional: narrow the thread to a specific module
  moduleId String?
  module   CourseModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)

  /// What level is this question targeting
  scope InstructionThreadScope @default(COURSE)

  /// Short subject line, e.g. "Confused about Big-O notation"
  subject String

  /// Thread lifecycle
  status InstructionThreadStatus @default(OPEN)

  /// Teacher can pin a thread so all enrolled students see it (FAQ-style)
  isPinned Boolean @default(false)

  /// true  → only the student who asked + the course teacher can see it
  /// false → all enrolled students can read it
  isPrivate Boolean @default(true)

  messages InstructionMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId, status])
  @@index([courseId, isPinned])
  @@index([studentId, createdAt])
  @@index([moduleId, status])
}

model InstructionMessage {
  id String @id @default(cuid())

  /// Which thread this message belongs to
  threadId String
  thread   InstructionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  /// null  → top-level message (the opening question)
  /// value → this message is a reply nested under parentId
  parentId String?
  parent   InstructionMessage?  @relation("MessageReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  InstructionMessage[] @relation("MessageReplies")

  /// Who wrote this message (student or teacher)
  authorId String
  author   User   @relation("MessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  /// The message body
  body String

  /// Convenience flag — lets the UI style teacher replies differently
  /// without having to join User.role on every render
  isTeacherReply Boolean @default(false)

  /// Soft-delete: body becomes "[deleted]" but row stays so
  /// nested replies are never orphaned
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([threadId, createdAt])
  @@index([parentId])
  @@index([authorId, createdAt])
}

/// Dynamic pages for website content management
model DynamicPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  published Boolean  @default(false)
  sections  AboutPage[]
  studentExperienceSections StudentExperience[]
  donationsSections DonationsSection[]
  admissionsSections AdmissionsSection[]
  tuitionSections TuitionSection[]
  governmentEmployeesSections GovernmentEmployeesSection[]
  homeSections HomeSection[]
  updatedById String?
  updatedBy User? @relation("PagesUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([published])
}

model AboutPage {
  id        String   @id @default(cuid())
  pageId    String
  page      DynamicPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  
  /// Section identifier (e.g., "hero", "history", "mission-vision")
  sectionKey String
  
  /// Section type component (e.g., "BannerSection", "IconCard", "TeamGrid")
  componentType String
  
  /// Position/order of section on the page
  position  Int      @default(0)
  
  /// Raw JSON content for the section
  content   Json
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pageId, sectionKey])
  @@index([pageId, position])
}

model StudentExperience {
  id        String   @id @default(cuid())
  pageId    String
  page      DynamicPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  
  /// Section identifier (e.g., "hero", "how-youll-learn", "learn-schedule")
  sectionKey String
  
  /// Section type component (e.g., "BannerSection", "IconCard", "CustomLearnSchedule")  
  componentType String
  
  /// Position/order of section on the page
  position  Int      @default(0)
  
  /// Raw JSON content for the section
  content   Json
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pageId, sectionKey])
  @@index([pageId, position])
}

// Additional dynamic page tables inferred from provided JSON payloads.
// These store page-level metadata and the full `sections` array as JSON
// so the frontend can render the page without changing existing About/StudentExperience schemas.
model TuitionPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  route     String
  sections  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model DonationsPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  route     String
  sections  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model GovernmentEmployeesPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  route     String
  sections  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model AdmissionsPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  route     String
  sections  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

// Per-page section tables mirroring the AboutPage and StudentExperience patterns.

model DonationsSection {
  id        String   @id @default(cuid())
  pageId    String
  page      DynamicPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  sectionKey String
  componentType String
  position  Int      @default(0)
  content   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pageId, sectionKey])
  @@index([pageId, position])
}

model AdmissionsSection {
  id        String   @id @default(cuid())
  pageId    String
  page      DynamicPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  sectionKey String
  componentType String
  position  Int      @default(0)
  content   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pageId, sectionKey])
  @@index([pageId, position])
}

model TuitionSection {
  id        String   @id @default(cuid())
  pageId    String
  page      DynamicPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  sectionKey String
  componentType String
  position  Int      @default(0)
  content   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pageId, sectionKey])
  @@index([pageId, position])
}

model GovernmentEmployeesSection {
  id        String   @id @default(cuid())
  pageId    String
  page      DynamicPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  sectionKey String
  componentType String
  position  Int      @default(0)
  content   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pageId, sectionKey])
  @@index([pageId, position])
}

