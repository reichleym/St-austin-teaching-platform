generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum SignupMode {
  INVITE_ONLY
  OPEN_WITH_CUTOFF
}

enum GradeEditRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EnrollmentStatus {
  ACTIVE
  DROPPED
  COMPLETED
}

enum CourseVisibility {
  DRAFT
  PUBLISHED
}

enum ModuleVisibilityRule {
  ALL_VISIBLE
  LIMITED_ACCESS
}

enum LessonVisibility {
  VISIBLE
  HIDDEN
}

enum LessonAttachmentKind {
  FILE
  PDF
  VIDEO_LINK
}

enum AdminActionType {
  INVITE_TEACHER
  INVITE_STUDENT
  ENABLE_USER
  DISABLE_USER
  TOGGLE_STUDENT_SELF_SIGNUP
  SET_SIGNUP_CUTOFF
  APPROVE_GRADE_EDIT_REQUEST
  REJECT_GRADE_EDIT_REQUEST
  CREATE_ANNOUNCEMENT
  UPDATE_ANNOUNCEMENT
  DELETE_ANNOUNCEMENT
  UPDATE_SYSTEM_SETTINGS
}

enum AnnouncementAudience {
  BOTH
  TEACHER_ONLY
  STUDENT_ONLY
}

model User {
  id                        String                    @id @default(cuid())
  name                      String?
  email                     String                    @unique
  emailVerified             DateTime?
  image                     String?
  passwordHash              String
  role                      Role                      @default(STUDENT)
  status                    UserStatus                @default(ACTIVE)
  phone                     String?
  guardianName              String?
  guardianPhone             String?
  country                   String?
  state                     String?
  department                String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  accounts                  Account[]
  sessions                  Session[]
  createdInvitations        Invitation[]              @relation("InvitationCreatedBy")
  createdAnnouncements      Announcement[]            @relation("AnnouncementCreatedBy")
  updatedAnnouncements      Announcement[]            @relation("AnnouncementUpdatedBy")
  taughtCourses             Course[]                  @relation("CourseTeacher")
  enrollments               Enrollment[]
  gradesAwarded             Grade[]                   @relation("GradeAwardedBy")
  gradeRecords              Grade[]                   @relation("GradeStudent")
  gradeEditSubjectRequests  GradeEditRequest[]        @relation("GradeEditStudent")
  discussionParticipations  DiscussionParticipation[]
  submittedGradeEditRequest GradeEditRequest[]        @relation("GradeEditRequestedBy")
  reviewedGradeEditRequest  GradeEditRequest[]        @relation("GradeEditReviewedBy")
  lessonCompletions         LessonCompletion[]
  adminActions              AdminActionLog[]          @relation("AdminActionActor")
  targetedAdminActions      AdminActionLog[]          @relation("AdminActionTargetUser")
  settingsUpdates           SystemSettings[]          @relation("SystemSettingsUpdatedBy")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Invitation {
  id          String    @id @default(cuid())
  email       String
  name        String?
  phone       String?
  department  String?
  guardianName String?
  guardianPhone String?
  country     String?
  state       String?
  role        Role
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdBy   User      @relation("InvitationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email])
  @@index([role, expiresAt])
}

model SystemSettings {
  id                         Int        @id @default(1)
  studentSelfSignupEnabled   Boolean    @default(false)
  studentSignupCutoffDate    DateTime?
  signupMode                 SignupMode @default(INVITE_ONLY)
  gradeScale                 Json?
  lateSubmissionPenaltyRules Json?
  updatedById                String?
  updatedBy                  User?      @relation("SystemSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt                  DateTime   @default(now())
  updatedAt                  DateTime   @updatedAt
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  isGlobal    Boolean   @default(true)
  audience    AnnouncementAudience @default(BOTH)
  expiresAt   DateTime?
  createdById String
  createdBy   User      @relation("AnnouncementCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById String?
  updatedBy   User?     @relation("AnnouncementUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isGlobal, expiresAt])
  @@index([audience, expiresAt])
}

model Course {
  id          String       @id @default(cuid())
  code        String       @unique
  title       String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  visibility  CourseVisibility @default(DRAFT)
  teacherId   String?
  teacher     User?        @relation("CourseTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  assignments Assignment[]
  discussions Discussion[]
  enrollments Enrollment[]
  modules     CourseModule[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model CourseModule {
  id             String               @id @default(cuid())
  courseId       String
  course         Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  position       Int                  @default(0)
  releaseAt      DateTime?
  visibilityRule ModuleVisibilityRule @default(ALL_VISIBLE)
  lessons        Lesson[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([courseId, position])
}

model Lesson {
  id            String           @id @default(cuid())
  moduleId      String
  module        CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title         String
  content       String?
  position      Int              @default(0)
  visibility    LessonVisibility @default(VISIBLE)
  isRequired    Boolean          @default(true)
  embedUrl      String?
  attachments   LessonAttachment[]
  completions   LessonCompletion[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([moduleId, position])
}

model LessonAttachment {
  id           String             @id @default(cuid())
  lessonId     String
  lesson       Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  kind         LessonAttachmentKind @default(FILE)
  label        String?
  fileName     String?
  mimeType     String?
  sizeBytes    Int?
  storageKey   String?
  publicUrl    String?
  createdAt    DateTime           @default(now())

  @@index([lessonId, kind])
}

model LessonCompletion {
  id          String    @id @default(cuid())
  lessonId    String
  studentId   String
  completedAt DateTime  @default(now())
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([lessonId, studentId])
  @@index([studentId, completedAt])
}

model Assignment {
  id                String             @id @default(cuid())
  courseId          String
  course            Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  dueAt             DateTime?
  maxPoints         Decimal            @default(100) @db.Decimal(6, 2)
  grades            Grade[]
  gradeEditRequests GradeEditRequest[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Discussion {
  id             String                    @id @default(cuid())
  courseId       String
  course         Course                    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title          String
  content        String?
  isClosed       Boolean                   @default(false)
  participations DiscussionParticipation[]
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
}

model DiscussionParticipation {
  id             String     @id @default(cuid())
  discussionId   String
  studentId      String
  postsCount     Int        @default(0)
  completionRate Int        @default(0)
  lastPostedAt   DateTime?
  discussion     Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  student        User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([discussionId, studentId])
}

model Enrollment {
  id         String           @id @default(cuid())
  courseId   String
  studentId  String
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  course     Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student    User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
}

model Grade {
  id           String     @id @default(cuid())
  assignmentId String
  studentId    String
  awardedById  String?
  points       Decimal    @db.Decimal(6, 2)
  publishedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User       @relation("GradeStudent", fields: [studentId], references: [id], onDelete: Cascade)
  awardedBy    User?      @relation("GradeAwardedBy", fields: [awardedById], references: [id], onDelete: SetNull)

  @@unique([assignmentId, studentId])
}

model GradeEditRequest {
  id             String                 @id @default(cuid())
  assignmentId   String
  studentId      String
  requestedById  String
  reason         String
  proposedPoints Decimal?               @db.Decimal(6, 2)
  status         GradeEditRequestStatus @default(PENDING)
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  assignment     Assignment             @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student        User                   @relation("GradeEditStudent", fields: [studentId], references: [id], onDelete: Cascade)
  requestedBy    User                   @relation("GradeEditRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  reviewedBy     User?                  @relation("GradeEditReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([assignmentId, studentId])
}

model AdminActionLog {
  id           String          @id @default(cuid())
  action       AdminActionType
  actorId      String
  targetUserId String?
  entityType   String?
  entityId     String?
  metadata     Json?
  createdAt    DateTime        @default(now())
  actor        User            @relation("AdminActionActor", fields: [actorId], references: [id], onDelete: Restrict)
  targetUser   User?           @relation("AdminActionTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([actorId, createdAt])
}
